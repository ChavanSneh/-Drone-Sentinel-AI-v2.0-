# 1. Virtual Environment
# This skips the .venv folder and all installed libraries
.venv/
venv/
env/
ENV/

# 2. Python artifacts
# Skips compiled code and cache
__pycache__/
*.py[cod]
*$py.class

# 3. Database
# Skips your local SQLite/JSON database file
drone_events.json
*.sqlite3


# 4. Images & Media
# Skips downloaded images or captured frames
test_images/
*.jpg
*.png
*.jpeg
# Also ignore your local database and virtual environment!
.venv/
__pycache__/

# 5. Environment Variables / Secrets
.env